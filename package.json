{
  "name": "prototype-comments",
  "version": "1.0.0",
  "type": "module",
  "description": "Drop-in Firebase comment overlay for HTML prototypes",
  "scripts": {
    "test:render": "open test/render-test.html",
    "test:e2e": "node test/e2e/e2e-mock.spec.js",
    "test:visual": "node test/visual/visual-shot.js",
    "test:visual:update": "node test/visual/visual-shot.js --update",
    "test": "npm run test:e2e && npm run test:visual"
